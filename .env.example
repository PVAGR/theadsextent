# PVA Bazaar Stream Embed – Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env (same folder as server.js) and fill in your values.
# The .env file is listed in .gitignore so your secrets are never committed.
#
# Lines starting with # are comments and are ignored.

# ── Twitch API ────────────────────────────────────────────────────────────────
# Get these from https://dev.twitch.tv/console/apps
# Create an app → "OAuth Redirect URL" = http://localhost:8888
# Copy Client ID and Client Secret below.
#
TWITCH_CLIENT_ID=YOUR_TWITCH_CLIENT_ID
TWITCH_CLIENT_SECRET=YOUR_TWITCH_CLIENT_SECRET
TWITCH_CHANNEL=ricktaur

# ── Site URL ──────────────────────────────────────────────────────────────────
# After deploying to Netlify, set this to your live URL.
# Used so Netlify Functions can call each other.
#
SITE_URL=http://localhost:8888

# ── Go-Live Notifications ─────────────────────────────────────────────────────
# Discord: Create a webhook in your server:
#   Server Settings → Integrations → Webhooks → New Webhook → Copy URL
#
DISCORD_WEBHOOK_URL=

# NOTIFY_SECRET: a random string you make up – used on the Go-Live panel
# to authorize the notification trigger. Set the same value in Netlify
# environment variables when you deploy.
NOTIFY_SECRET=change-me-to-something-random

# ── Revenue Dashboard Protection (optional) ───────────────────────────────────
# If set, the /revenue GET endpoint requires: Authorization: Bearer <value>
# Leave blank to allow open access (fine locally, lock down in production).
REVENUE_SECRET=
