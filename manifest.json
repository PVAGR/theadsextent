{
  "manifest_version": 3,
  "name": "theadsextent",
  "version": "1.0.0",
  "description": "A browser extension for managing and extending ad-related functionality.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "theadsextent"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
